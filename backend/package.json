{
  "name": "backend",
  "version": "1.0.0",
  "description": "Todo Application Backend API",
  "main": "server.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node server.ts",
    "worker:dev": "nodemon --exec ts-node src/workers/todo.worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/src/workers/todo.worker.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:status": "sequelize-cli db:migrate:status",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo",
    "db:dump": "node scripts/create-dump.bat",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPatterns=unit --coverage",
    "test:integration": "jest --testPathPatterns=integration --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "todo",
    "api",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "mysql2": "^3.19.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.0",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
